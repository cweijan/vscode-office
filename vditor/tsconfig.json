{
  "compilerOptions": {
    "outDir": "./dist/",
    "noImplicitAny": true,
    "module": "esnext",
    "moduleResolution": "node",
    "target": "es2019",
    "noUnusedLocals": false,
    "lib": [
      "dom",
      "ESNext"
    ],
    "typeRoots": [
      "./node_modules/@types"
    ],
    "declaration": true,
    "resolveJsonModule": true,
    "strict": false,
    "skipLibCheck": true
  },
  "include": [
    "src"
  ],
  "files": [
    "types/index.d.ts"
  ],
  "exclude": [
    "node_modules",
  ]
}
