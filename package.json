{
	"name": "vscode-office",
	"displayName": "Office Viewer",
	"description": "View word, excel, powerpoint files and using WYSIWYG editor for markdown.",
	"version": "4.0.2",
	"publisher": "cweijan",
	"icon": "images/logo.png",
	"engines": {
		"vscode": "^1.64.0"
	},
	"keywords": [
		"pdf",
		"word",
		"docx",
		"excel",
		"xlsx",
		"csv",
		"powerpoint",
		"pptx",
		"markdown",
		"epub",
		"svg",
		"psd",
		"xmind",
		"zip",
		"archive",
		"font",
		"toml",
		"yaml"
	],
	"categories": [
		"Visualization",
		"Other"
	],
	"bugs": {
		"url": "https://github.com/cweijan/vscode-office/issues",
		"email": "cweijan@163.com"
	},
	"homepage": "https://github.com/cweijan/vscode-office/blob/master/README.md",
	"repository": {
		"type": "git",
		"url": "https://github.com/cweijan/vscode-office.git"
	},
	"activationEvents": [
		"onStartupFinished"
	],
	"main": "./out/extension.js",
	"contributes": {
		"themes": [
			{
				"label": "One Dark Modern",
				"uiTheme": "vs-dark",
				"path": "./theme/onedark-modern.json"
			},
			{
				"label": "One Dark Modern Classic",
				"uiTheme": "vs-dark",
				"path": "./theme/onedark-modern-classic.json"
			}
		],
		"iconThemes": [
			{
				"id": "office-material-icon-theme",
				"label": "Office Material Icon Theme",
				"path": "./theme/material-icons.json",
				"_watch": true
			}
		],
		"languages": [
			{
				"id": "reg",
				"aliases": [
					"REG",
					"reg"
				],
				"extensions": [
					".reg",
					".REG"
				],
				"configuration": "./syntaxes/reg-language-configuration.json"
			},
			{
				"id": "http",
				"aliases": [
					"HTTP",
					"Http",
					"http"
				],
				"extensions": [
					".http",
					".rest"
				],
				"firstLine": "^(GET|POST|PUT|DELETE|PATCH|HEAD|OPTIONS|CONNECT|TRACE)\\s+(.*?)HTTP/[0-9\\.]+$",
				"configuration": "./syntaxes/http-language-configuration.json"
			},
			{
				"id": "toml",
				"aliases": [
					"TOML",
					"Toml",
					"toml"
				],
				"extensions": [
					".toml"
				],
				"configuration": "./syntaxes/toml-language-configuration.json"
			}
		],
		"grammars": [
			{
				"language": "reg",
				"scopeName": "source.reg",
				"path": "./syntaxes/reg.tmLanguage"
			},
			{
				"language": "http",
				"scopeName": "source.http",
				"path": "./syntaxes/http.tmLanguage.json"
			},
			{
				"language": "toml",
				"scopeName": "source.toml",
				"path": "./syntaxes/toml.tmLanguage.json"
			}
		],
		"snippets": [
			{
				"language": "http",
				"path": "./snippets/http.json"
			}
		],
		"commands": [
			{
				"command": "vscode-office.save-response-body",
				"title": "Save Response",
				"icon": "$(save)"
			},
			{
				"command": "vscode-office.copy-response-body",
				"title": "Copy Response",
				"icon": "$(copy)"
			},
			{
				"command": "office.reg.jumpToKey",
				"title": "REG: Jump to registry key"
			},
			{
				"command": "office.markdown.switch",
				"title": "Switch markdown editor",
				"icon": {
					"dark": "./images/switch.svg",
					"light": "./images/switch_light.svg"
				}
			},
			{
				"command": "office.markdown.paste",
				"title": "Enhance pater in markdown"
			},
			{
				"command": "office.html.preview",
				"title": "Preview HTML"
			}
		],
		"keybindings": [
			{
				"command": "office.markdown.paste",
				"key": "ctrl+v",
				"mac": "cmd+v",
				"when": "editorTextFocus && resourceLangId == markdown"
			},
			{
				"command": "office.html.preview",
				"key": "ctrl+shift+v",
				"when": "editorTextFocus && editorLangId == html"
			},
			{
				"command": "office.markdown.switch",
				"key": "ctrl+alt+e",
				"mac": "ctrl+cmd+e",
				"when": "editorTextFocus && editorLangId == markdown"
			},
			{
				"command": "vscode-office.request",
				"key": "ctrl+enter",
				"mac": "cmd+enter",
				"when": "editorTextFocus && editorLangId == 'http'"
			}
		],
		"menus": {
			"editor/title": [
				{
					"command": "office.markdown.switch",
					"when": "resourceExtname == '.md'",
					"group": "navigation@-2"
				},
				{
					"when": "editorTextFocus && resourceScheme == rest-client-response",
					"command": "vscode-office.copy-response-body",
					"group": "navigation@0"
				},
				{
					"when": "editorTextFocus && resourceScheme == rest-client-response",
					"command": "vscode-office.save-response-body",
					"group": "navigation@2"
				}
			],
			"editor/context": [
				{
					"command": "office.html.preview",
					"group": "navigation@1",
					"when": "editorTextFocus && editorLangId == html"
				},
				{
					"command": "vscode-office.save-response-body",
					"group": "http@2",
					"when": "editorTextFocus && resourceScheme == rest-client-response"
				},
				{
					"command": "vscode-office.copy-response-body",
					"group": "http@4",
					"when": "editorTextFocus && resourceScheme == rest-client-response"
				}
			]
		},
		"customEditors": [
			{
				"viewType": "cweijan.officeViewer",
				"displayName": "Office Viewer",
				"selector": [
					{
						"filenamePattern": "*.xlsx"
					},
					{
						"filenamePattern": "*.xlsm"
					},
					{
						"filenamePattern": "*.csv"
					},
					{
						"filenamePattern": "*.xls"
					},
					{
						"filenamePattern": "*.ods"
					},
					{
						"filenamePattern": "*.docx"
					},
					{
						"filenamePattern": "*.dotx"
					},
					{
						"filenamePattern": "*.pptx"
					},
					{
						"filenamePattern": "*.pptm"
					},
					{
						"filenamePattern": "*.pdf"
					},
					{
						"filenamePattern": "*.epub"
					},
					{
						"filenamePattern": "*.ttf"
					},
					{
						"filenamePattern": "*.woff"
					},
					{
						"filenamePattern": "*.woff2"
					},
					{
						"filenamePattern": "*.otf"
					},
					{
						"filenamePattern": "*.jar"
					},
					{
						"filenamePattern": "*.zip"
					},
					{
						"filenamePattern": "*.7z"
					},
					{
						"filenamePattern": "*.rar"
					},
					{
						"filenamePattern": "*.tar.gz"
					},
					{
						"filenamePattern": "*.tgz"
					},
					{
						"filenamePattern": "*.apk"
					},
					{
						"filenamePattern": "*.vsix"
					},
					{
						"filenamePattern": "*.svg"
					}
				]
			},
			{
				"viewType": "cweijan.heicTiffViewer",
				"displayName": "Image Preview(Office Viewer)",
				"selector": [
					{
						"filenamePattern": "*.heic"
					},
					{
						"filenamePattern": "*.heif"
					},
					{
						"filenamePattern": "*.tiff"
					}
				]
			},
			{
				"viewType": "cweijan.imageViewer",
				"displayName": "Image Preview(Office Viewer)",
				"priority": "option",
				"selector": [
					{
						"filenamePattern": "*.jpg"
					},
					{
						"filenamePattern": "*.png"
					},
					{
						"filenamePattern": "*.gif"
					},
					{
						"filenamePattern": "*.apng"
					},
					{
						"filenamePattern": "*.apng"
					},
					{
						"filenamePattern": "*.bmp"
					},
					{
						"filenamePattern": "*.ico"
					},
					{
						"filenamePattern": "*.cur"
					},
					{
						"filenamePattern": "*.jpeg"
					},
					{
						"filenamePattern": "*.pjpeg"
					},
					{
						"filenamePattern": "*.pjp"
					},
					{
						"filenamePattern": "*.tif"
					},
					{
						"filenamePattern": "*.webp"
					}
				]
			},
			{
				"viewType": "cweijan.icnsViewer",
				"displayName": "ICNS Viewer",
				"selector": [
					{
						"filenamePattern": "*.icns"
					}
				]
			},
			{
				"viewType": "cweijan.psdViewer",
				"displayName": "PSD Viewer",
				"selector": [
					{
						"filenamePattern": "*.psd"
					}
				]
			},
			{
				"viewType": "cweijan.xmindViewer",
				"displayName": "XMind Viewer",
				"selector": [
					{
						"filenamePattern": "*.xmind"
					}
				]
			},
			{
				"viewType": "cweijan.markdownViewer",
				"displayName": "Markdown Editor",
				"selector": [
					{
						"filenamePattern": "file:/**/*.md"
					},
					{
						"filenamePattern": "file:/**/*.markdown"
					}
				]
			},
			{
				"viewType": "cweijan.markdownViewer.optional",
				"displayName": "Markdown Editor (Optional)",
				"priority": "option",
				"selector": [
					{
						"filenamePattern": "*.md"
					},
					{
						"filenamePattern": "*.markdown"
					}
				]
			},
			{
				"viewType": "cweijan.htmlViewer",
				"displayName": "Html Viewer",
				"priority": "option",
				"selector": [
					{
						"filenamePattern": "*.html"
					},
					{
						"filenamePattern": "*.htm"
					}
				]
			},
			{
				"viewType": "cweijan.classViewer",
				"displayName": "Java Decompiler",
				"selector": [
					{
						"filenamePattern": "file:/**/*.class"
					}
				]
			}
		],
		"configuration": [
			{
				"title": "Markdown",
				"order": 1,
				"properties": {
					"vscode-office.viewAbsoluteLocal": {
						"type": "boolean",
						"default": false,
						"description": "Support view absolute path image from markdown viewer."
					},
					"vscode-office.openOutline": {
						"type": "boolean",
						"default": true,
						"description": "Open markdown outline."
					},
					"vscode-office.hideToolbar": {
						"type": "boolean",
						"default": false,
						"description": "Hide markdown toolbar."
					},
					"vscode-office.previewCode": {
						"type": "boolean",
						"default": true,
						"description": "Preview code in markdown."
					},
					"vscode-office.preventMacOptionKey": {
						"type": "boolean",
						"default": true,
						"description": "Prevent MacOS option key in the markdown editor."
					},
					"vscode-office.editorTheme": {
						"type": "string",
						"enum": [
							"Auto",
							"Light",
							"Solarized",
							"Warm Light",
							"Dim Light",
							"One Dark",
							"Github Dark",
							"Nord",
							"Monokai",
							"Dracula"
						],
						"default": "Auto",
						"markdownDescription": "The theme for the Markdown editor."
					},
					"vscode-office.previewCodeHighlight.style": {
						"type": "string",
						"enum": [
							"abap",
							"algol",
							"algol_nu",
							"arduino",
							"autumn",
							"borland",
							"bw",
							"colorful",
							"dracula",
							"emacs",
							"friendly",
							"fruity",
							"github",
							"igor",
							"lovelace",
							"manni",
							"monokai",
							"monokailight",
							"murphy",
							"native",
							"paraiso-dark",
							"paraiso-light",
							"pastie",
							"perldoc",
							"pygments",
							"rainbow_dash",
							"rrt",
							"solarized-dark",
							"solarized-dark256",
							"solarized-light",
							"swapoff",
							"tango",
							"trac",
							"vim",
							"vs",
							"xcode",
							"ant-design"
						],
						"default": "dracula",
						"markdownDescription": "Default syntax highlight style of markdown preview code. Refer to [Chroma Style Gallery](https://xyproto.github.io/splash/docs/longer/all.html). Only applies when `#vscode-office.previewCode#` is enabled."
					},
					"vscode-office.previewCodeHighlight.showLineNumber": {
						"type": "boolean",
						"default": true,
						"markdownDescription": "Show line numbers in markdown preview code window. Only applies when `#vscode-office.previewCode#` is enabled."
					},
					"vscode-office.editorLanguage": {
						"type": "string",
						"enum": [
							"en_US",
							"ja_JP",
							"ko_KR",
							"ru_RU",
							"zh_CN",
							"zh_TW"
						],
						"default": "en_US",
						"description": "You could change your editor language."
					},
					"vscode-office.workspacePathAsImageBasePath": {
						"type": "boolean",
						"default": false,
						"description": "Using workspace path as markdown image base path."
					},
					"vscode-office.pasterImgPath": {
						"type": "string",
						"default": "image/${fileName}/${now}.png",
						"description": "Markdown paste image path, variables: workspaceDir, fileName, now."
					}
				}
			},
			{
				"title": "Markdown PDF",
				"order": 2,
				"properties": {
					"vscode-office.chromiumPath": {
						"type": "string",
						"description": "Set the chromium browser location for exporting markdown pdf."
					},
					"vscode-office.puppeteerArgs": {
						"type": "array",
						"items": {
							"type": "string"
						},
						"default": [],
						"description": "Additional arguments to pass to Puppeteer/Chromium when exporting PDF. Example: [\"--no-sandbox\", \"--disable-setuid-sandbox\"] for Linux servers running as root."
					},
					"vscode-office.pdfMarginTop": {
						"type": "integer",
						"default": 25,
						"description": "Printed pdf default top margin."
					}
				}
			},
			{
				"title": "HTTP Client",
				"order": 3,
				"properties": {
					"vscode-office.followredirect": {
						"type": "boolean",
						"default": true,
						"scope": "resource",
						"description": "Follow HTTP 3xx responses as redirects."
					},
					"vscode-office.environmentVariables": {
						"type": "object",
						"default": {
							"$shared": {}
						},
						"scope": "resource",
						"markdownDescription": "Sets the environments and custom variables belongs to it."
					},
					"vscode-office.previewOption": {
						"type": "string",
						"enum": [
							"full",
							"headers",
							"body",
							"exchange"
						],
						"default": "body",
						"scope": "resource",
						"description": "Response preview output option"
					},
					"vscode-office.previewColumn": {
						"type": "string",
						"enum": [
							"current",
							"beside"
						],
						"default": "beside",
						"scope": "resource",
						"description": "Response preview column option"
					},
					"vscode-office.formParamEncodingStrategy": {
						"type": "string",
						"enum": [
							"automatic",
							"never",
							"always"
						],
						"default": "automatic",
						"scope": "resource",
						"description": "Form param encoding strategy for x-www-form-urlencoded body"
					},
					"vscode-office.addRequestBodyLineIndentationAroundBrackets": {
						"type": "boolean",
						"default": true,
						"scope": "resource",
						"description": "Add line indentation around brackets in request body"
					},
					"vscode-office.decodeEscapedUnicodeCharacters": {
						"type": "boolean",
						"default": false,
						"scope": "resource",
						"description": "Decode escaped unicode characters in response body."
					},
					"vscode-office.logLevel": {
						"type": "string",
						"enum": [
							"error",
							"warn",
							"info",
							"verbose"
						],
						"default": "error",
						"scope": "resource",
						"description": "The verbosity of logging in the REST output panel"
					},
					"vscode-office.enableCustomVariableReferencesCodeLens": {
						"type": "boolean",
						"default": true,
						"scope": "resource",
						"description": "Enable custom variable references CodeLens in request file"
					}
				}
			}
		]
	},
	"scripts": {
		"dev": "vite --mode=development",
		"lint:fix": "eslint src/**/*.ts --fix",
		"build": "rm -rf out && vite build --mode=production",
		"package": "vsce package --no-dependencies",
		"publish": "vsce publish --no-dependencies && ovsx publish --no-dependencies",
		"vscode:prepublish": "npm run build"
	},
	"devDependencies": {
		"@types/node": "^22.10.0",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@types/vscode": "^1.64.0",
		"@typescript-eslint/eslint-plugin": "^7.1.1",
		"@typescript-eslint/parser": "^7.1.1",
		"@vitejs/plugin-react": "^6.0.2",
		"esbuild": "^0.14.54",
		"esbuild-plugin-copy": "^1.3.0",
		"eslint": "^8.57.0",
		"eslint-plugin-import": "^2.29.1",
		"eslint-plugin-react": "^7.34.1",
		"eslint-plugin-react-hooks": "^7.1.1",
		"eslint-plugin-react-refresh": "^0.4.6",
		"eslint-plugin-unused-imports": "^3.1.0",
		"less": "^4.2.0",
		"node-unrar-js": "^2.0.2",
		"vite": "^8.0.16"
	},
	"dependencies": {
		"7z-wasm": "^1.2.0",
		"@ant-design/icons": "^5.3.5",
		"@codemirror/commands": "^6.10.3",
		"@codemirror/lang-xml": "^6.1.0",
		"@codemirror/language": "^6.12.3",
		"@codemirror/state": "^6.6.0",
		"@codemirror/view": "^6.43.1",
		"@lezer/highlight": "^1.2.3",
		"@mind-elixir/import-xmind": "^1.0.8",
		"@zip.js/zip.js": "^2.8.26",
		"ag-psd": "^30.1.1",
		"antd": "^5.15.4",
		"axios": "^1.4.0",
		"chart.js": "^4.5.1",
		"cheerio": "^1.0.0",
		"chrome-finder": "^1.0.7",
		"date-format": "^4.0.14",
		"docx-preview": "^0.3.0",
		"epubjs": "^0.3.93",
		"exceljs": "^4.4.0",
		"file-type": "^19.6.0",
		"heic2any": "^0.0.4",
		"highlight.js": "^11.10.0",
		"iconv-lite": "^0.6.3",
		"jszip": "^3.10.1",
		"katex": "^0.16.2",
		"markdown-it": "^14.1.0",
		"markdown-it-anchor": "^9.2.0",
		"markdown-it-checkbox": "^1.1.0",
		"markdown-it-plantuml": "^1.4.1",
		"markdown-it-toc-done-right": "^4.2.0",
		"mermaid": "^11.15.0",
		"mind-elixir": "^5.12.2",
		"mustache": "^4.0.1",
		"opentype.js": "1.3.4",
		"pdf-lib": "^1.11.2",
		"pptxviewjs": "^1.1.9",
		"puppeteer-core": "^25.1.0",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"react-image-gallery": "^1.3.0",
		"tar": "^7.5.16",
		"udsv": "^0.5.3",
		"utif": "^3.1.0",
		"vscode-html-to-docx": "^1.1.2",
		"x-data-spreadsheet": "^1.1.9",
		"xlsx": "^0.18.5",
		"yaml": "^2.9.0"
	}
}
